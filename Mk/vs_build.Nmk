        $(VR_API_OBJECT)\valdirect_api.obj \
        $(VR_API_OBJECT)\valset_api.obj

OBJECT_FILES = $(OBJS) $(AFX_OBJS) $(API_OBJS)


# Source file names.

# Source file names are implied by 'OBJS', 'AFX_OBS' and API_OBJS.

# The build directory 'V3R0' is created in v3r0_vs_<std>_copy.Makefile.

$(VR_OBJECT) : $(VR_DIRECTORY)
	mkdir $(VR_OBJECT)

$(VR_STDAFX_OBJECT) : $(VR_OBJECT)
	mkdir $(VR_STDAFX_OBJECT)

$(VR_API_OBJECT) : $(VR_OBJECT)
	mkdir $(VR_API_OBJECT)

OBJECT_DIRECTORIES = $(VR_STDAFX_OBJECT) $(VR_API_OBJECT)

# Compiler settings.

CXX = $(PATH_TO_CXX)$(COMPILER)
DEFOPTS = $(DEFINES) $(OPTIONS)
CXXEXTRA = -D_BBDBAPI -EHsc -nologo -std:$(CPPSTANDARD)
VR_LDFLAGS = -dll

# Build includes (-I) options for compiler.

VR_INCLUDE = -I$(VR_INC) -I$(VR_STDAFX)
VR_AFX_INCLUDE = -I$(VR_INC) -I$(VR_STDAFX)
VR_API_INCLUDE = -I$(VR_INC) -I$(VR_API_INC) -I$(VR_STDAFX)

# Pattern rules V3R0 C++.

{$(VR_SRC)}.cpp{$(VR_OBJECT)}.obj:
	@$(CXX) -c $(CXXEXTRA) $(CXXFLAGS) $(VR_INCLUDE) $(DEFOPTS) -Fo$(VR_OBJECT)\ $<

{$(VR_STDAFX)}.cpp{$(VR_STDAFX_OBJECT)}.obj:
	@$(CXX) -c $(CXXEXTRA) $(CXXFLAGS) $(VR_AFX_INCLUDE) $(DEFOPTS) -Fo$(VR_STDAFX_OBJECT)\ $<

{$(VR_API_SRC)}.cpp{$(VR_API_OBJECT)}.obj:
	@$(CXX) -c $(CXXEXTRA) $(CXXFLAGS) $(VR_API_INCLUDE) $(DEFOPTS) -Fo$(VR_API_OBJECT)\ $<

