AFX_OBJS = $(VR_STDAFX_OBJECT)\stdafx.obj


API_OBJS = $(VR_API_OBJECT)\access_api.obj \
        $(VR_API_OBJECT)\bmset_api.obj \
        $(VR_API_OBJECT)\core_api.obj \
        $(VR_API_OBJECT)\ctxtspec_api.obj \
        $(VR_API_OBJECT)\cursor_api.obj \
        $(VR_API_OBJECT)\dbctxt_api.obj \
        $(VR_API_OBJECT)\dbserv_api.obj \
        $(VR_API_OBJECT)\fieldatts_api.obj \
        $(VR_API_OBJECT)\fieldinfo_api.obj \
        $(VR_API_OBJECT)\fieldval_api.obj \
        $(VR_API_OBJECT)\findspec_api.obj \
        $(VR_API_OBJECT)\floatnum_api.obj \
        $(VR_API_OBJECT)\foundset_api.obj \
        $(VR_API_OBJECT)\grpserv_api.obj \
        $(VR_API_OBJECT)\msgroute_api.obj \
        $(VR_API_OBJECT)\parmvr_api.obj \
        $(VR_API_OBJECT)\reccopy_api.obj \
        $(VR_API_OBJECT)\reclist_api.obj \
        $(VR_API_OBJECT)\record_api.obj \
        $(VR_API_OBJECT)\recread_api.obj \
        $(VR_API_OBJECT)\recset_api.obj \
        $(VR_API_OBJECT)\seqfile_api.obj \
        $(VR_API_OBJECT)\seqserv_api.obj \
