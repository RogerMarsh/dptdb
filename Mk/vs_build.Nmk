# vs_build.Nmk
# Build version with c++ in a Microsoft VS Developer Command Prompt.

# Compiler settings.

PATH_TO_CXX = 

# Include this file in a makefile that defines these variables:
# TOOL_CHAIN
# TOOL_CHAIN_VERSION
# CPPSTANDARD

# Version extract and build folders.

DPT = dpt
EXTRACT = $(DPT)\extract
BUILD = $(DPT)\$(TOOL_CHAIN)$(TOOL_CHAIN_VERSION)_$(COMPILER)_$(CPPSTANDARD)
VR_DIRECTORY = $(BUILD)\$(DPT_VERSION)
VR_SRC = $(VR_DIRECTORY)\source
VR_INC = $(VR_DIRECTORY)\include
DPT_LICENCE = licence.txt
VR_API_SRC = $(VR_SRC)\dbapi
VR_API_INC = $(VR_INC)\dbapi
VR_STDAFX = $(VR_DIRECTORY)\stdafx
VR_OBJECT = $(VR_DIRECTORY)\object
VR_API_OBJECT = $(VR_OBJECT)\dbapi
VR_STDAFX_OBJECT = $(VR_OBJECT)\stdafx

# Object file names.

